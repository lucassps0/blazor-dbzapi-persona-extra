@page "/"
@using System.Text.Json
@inject HttpClient Http

<PageTitle>Dragon Ball Persona Extra</PageTitle>

<h1>Dragon Ball Persona Extra</h1>

<div class="form-group mb-3">
    <label for="idInput" class="form-label">Digite o id do personagem:</label>
    <input type="number" id="idInput" class="form-control" @bind="idPersonagem" placeholder="Ex: 1" />
</div>

<button class="btn btn-primary" @onclick="ConsultarPersonagem">Consultar</button>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger mt-3">@errorMessage</div>
}
else if (personagem != null)
{
    <div class="card mt-3" style="max-width: 420px;">
        <img src="@personagem.Image" class="card-img-top bg-light" alt="@personagem.Name" style="height: 300px; object-fit: contain;" />
        <div class="card-body">
            <h5 class="card-title">Personagem Encontrado</h5>
            <p class="card-text"><strong>Nome:</strong> @personagem.Name</p>
            <p class="card-text"><strong>Raça:</strong> @personagem.Race</p>
        </div>
    </div>
}

@code {
    private string idPersonagem = "1";
    private Personagem? personagem;
    private string? errorMessage;

    private async Task ConsultarPersonagem()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(idPersonagem))
            {
                personagem = null;
                errorMessage = "Digite um id.";
                return;
            }

            var response = await Http.GetAsync($"https://dragonball-api.com/api/characters/{idPersonagem}");

            if (!response.IsSuccessStatusCode)
            {
                personagem = null;
                errorMessage = "Personagem não encontrado.";
                return;
            }

            var jsonResponse = await response.Content.ReadAsStringAsync();
            personagem = JsonSerializer.Deserialize<Personagem>(jsonResponse, new JsonSerializerOptions
            {
                PropertyNameCaseInsensitive = true
            });

            errorMessage = null;
        }
        catch (Exception ex)
        {
            personagem = null;
            errorMessage = $"Erro ao consultar personagem: {ex.Message}";
        }
    }

    public class Personagem
    {
        public string? Name { get; set; }
        public string? Race { get; set; }
        public string? Image { get; set; }
    }
}
